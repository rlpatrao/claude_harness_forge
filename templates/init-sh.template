#!/usr/bin/env bash
# ===========================================
# Project Bootstrap Script
# Generated by claude_harness_forge scaffold
# ===========================================
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

echo "=== Bootstrapping {{PROJECT_NAME}} ==="

# ---------- Backend Setup ----------
if [ -d "backend" ]; then
    echo "→ Setting up backend..."
    cd backend

    # Create virtual environment
    if [ ! -d ".venv" ]; then
        python3 -m venv .venv
    fi
    source .venv/bin/activate

    # Install dependencies
    if [ -f "requirements.txt" ]; then
        pip install -r requirements.txt
    fi

    # Run migrations
    if [ -f "alembic.ini" ]; then
        alembic upgrade head
    fi

    cd "$PROJECT_ROOT"
fi

# ---------- Frontend Setup ----------
if [ -d "frontend" ]; then
    echo "→ Setting up frontend..."
    cd frontend

    # Install dependencies
    if [ -f "package.json" ]; then
        npm ci
    fi

    cd "$PROJECT_ROOT"
fi

# ---------- Docker Setup ----------
if [ -f "docker-compose.yml" ]; then
    echo "→ Starting Docker services..."
    docker compose up -d

    # Wait for database health
    echo "→ Waiting for database..."
    RETRIES=30
    until docker compose exec -T db pg_isready -U postgres > /dev/null 2>&1 || [ $RETRIES -eq 0 ]; do
        echo "  Waiting for PostgreSQL... ($RETRIES attempts remaining)"
        RETRIES=$((RETRIES - 1))
        sleep 2
    done

    if [ $RETRIES -eq 0 ]; then
        echo "ERROR: Database did not become ready"
        exit 1
    fi

    echo "✓ Database ready"
fi

# ---------- Environment ----------
if [ ! -f ".env" ] && [ -f ".env.example" ]; then
    echo "→ Creating .env from .env.example..."
    cp .env.example .env
    echo "  ⚠ Edit .env with your actual values"
fi

# ---------- Playwright ----------
if [ -f "playwright.config.ts" ]; then
    echo "→ Installing Playwright browsers..."
    npx playwright install --with-deps chromium
fi

echo ""
echo "=== {{PROJECT_NAME}} bootstrap complete ==="
echo "Run 'docker compose logs -f' to watch service logs"
