.PHONY: install dev test lint clean docker-up docker-down migrate seed help

# =============================================================================
# {{PROJECT_NAME}}
# Generated by Claude Harness Forge
# =============================================================================

# Configuration
BACKEND_DIR := backend
FRONTEND_DIR := frontend
VENV := $(BACKEND_DIR)/.venv
PYTHON := $(VENV)/bin/python3
PIP := $(VENV)/bin/pip
PYTEST := $(VENV)/bin/pytest
RUFF := $(VENV)/bin/ruff
MYPY := $(VENV)/bin/mypy
ALEMBIC := $(VENV)/bin/alembic

# Default target
help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}'

# =============================================================================
# Installation
# =============================================================================

install: install-backend install-frontend ## Install all dependencies

install-backend: ## Install backend dependencies
	@echo "==> Installing backend..."
	cd $(BACKEND_DIR) && python3 -m venv .venv
	$(PIP) install --upgrade pip
	$(PIP) install -e ".[dev]"

install-frontend: ## Install frontend dependencies
	@echo "==> Installing frontend..."
	cd $(FRONTEND_DIR) && npm install

# =============================================================================
# Development
# =============================================================================

dev: ## Start all development servers
	@echo "==> Starting development servers..."
	@make -j2 dev-backend dev-frontend

dev-backend: ## Start backend server
	cd $(BACKEND_DIR) && $(VENV)/bin/uvicorn app.main:app --reload --port 8000

dev-frontend: ## Start frontend dev server
	cd $(FRONTEND_DIR) && npm run dev

# =============================================================================
# Testing
# =============================================================================

test: test-backend test-frontend ## Run all tests

test-backend: ## Run backend tests
	cd $(BACKEND_DIR) && $(PYTEST) tests/ -q --tb=short

test-frontend: ## Run frontend tests
	cd $(FRONTEND_DIR) && npx vitest run --reporter=verbose

test-coverage: ## Run tests with coverage
	cd $(BACKEND_DIR) && $(PYTEST) tests/ -q --cov=app --cov-report=term-missing --cov-report=html

test-watch: ## Run tests in watch mode
	cd $(BACKEND_DIR) && $(PYTEST) tests/ --watch

# =============================================================================
# Linting & Type Checking
# =============================================================================

lint: lint-backend lint-frontend ## Run all linters

lint-backend: ## Lint backend
	cd $(BACKEND_DIR) && $(RUFF) check app/ tests/
	cd $(BACKEND_DIR) && $(RUFF) format --check app/ tests/

lint-frontend: ## Lint frontend
	cd $(FRONTEND_DIR) && npx eslint src/ --ext .ts,.tsx

lint-fix: ## Auto-fix lint issues
	cd $(BACKEND_DIR) && $(RUFF) check --fix app/ tests/
	cd $(BACKEND_DIR) && $(RUFF) format app/ tests/
	cd $(FRONTEND_DIR) && npx eslint src/ --ext .ts,.tsx --fix

typecheck: ## Run type checkers
	cd $(BACKEND_DIR) && $(MYPY) app/ --ignore-missing-imports
	cd $(FRONTEND_DIR) && npx tsc --noEmit

# =============================================================================
# Database
# =============================================================================

migrate: ## Run database migrations
	cd $(BACKEND_DIR) && $(ALEMBIC) upgrade head

migrate-new: ## Create a new migration (usage: make migrate-new MSG="add users table")
	cd $(BACKEND_DIR) && $(ALEMBIC) revision --autogenerate -m "$(MSG)"

migrate-down: ## Rollback one migration
	cd $(BACKEND_DIR) && $(ALEMBIC) downgrade -1

seed: ## Seed database with initial data
	cd $(BACKEND_DIR) && $(PYTHON) -m app.scripts.seed

# =============================================================================
# Docker
# =============================================================================

docker-up: ## Start all Docker services
	docker compose up -d

docker-down: ## Stop all Docker services
	docker compose down

docker-logs: ## Show Docker logs
	docker compose logs -f

docker-db: ## Start only the database
	docker compose up -d db

docker-reset: ## Reset database (destroy + recreate)
	docker compose down -v
	docker compose up -d db
	@echo "Waiting for database..."
	@until docker compose exec db pg_isready -U postgres 2>/dev/null; do sleep 2; done
	@echo "Database ready. Run 'make migrate' to create tables."

# =============================================================================
# Build & Deploy
# =============================================================================

build: ## Build for production
	cd $(FRONTEND_DIR) && npm run build
	@echo "Frontend built to $(FRONTEND_DIR)/dist/"

# =============================================================================
# Cleanup
# =============================================================================

clean: ## Remove generated files
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .mypy_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .ruff_cache -exec rm -rf {} + 2>/dev/null || true
	find . -name "*.pyc" -delete 2>/dev/null || true
	rm -rf $(BACKEND_DIR)/htmlcov $(FRONTEND_DIR)/dist

clean-all: clean ## Remove all generated files including venv and node_modules
	rm -rf $(BACKEND_DIR)/.venv $(FRONTEND_DIR)/node_modules
